{
    "name": "n8n-nodes-vies",
    "version": "1.0.1",
    "description": "n8n community node for VIES - EU VAT number validation via European Commission",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "vies",
        "vat",
        "eu",
        "europe",
        "tax",
        "validation"
    ],
    "license": "MIT",
    "author": {
        "name": "Michal Ploneczka",
        "email": "michal.ploneczka@gmail.com",
        "url": "https://codersgroup.pl"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/michalploneczka/n8n-polish-nodes.git",
        "directory": "packages/n8n-nodes-vies"
    },
    "homepage": "https://github.com/michalploneczka/n8n-polish-nodes/tree/main/packages/n8n-nodes-vies#readme",
    "scripts": {
        "build": "n8n-node build && node ../../scripts/copy-codex.js",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "test": "jest --config jest.config.js",
        "clean": "rm -rf dist"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": false,
        "credentials": [],
        "nodes": [
            "dist/nodes/Vies/Vies.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
