{
  "name": "n8n-nodes-nbp",
  "version": "1.0.0",
  "description": "n8n community node for NBP - official Polish exchange rates and gold prices from National Bank of Poland",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "nbp",
    "exchange-rate",
    "currency",
    "gold",
    "poland",
    "polish",
    "national-bank"
  ],
  "license": "MIT",
  "author": {
    "name": "Michal Ploneczka",
    "email": "michal.ploneczka@gmail.com",
    "url": "https://codersgroup.pl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michalploneczka/n8n-polish-nodes.git",
    "directory": "packages/n8n-nodes-nbp"
  },
  "scripts": {
    "build": "n8n-node build && node ../../scripts/copy-codex.js",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "test": "jest --config jest.config.js",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [],
    "nodes": [
      "dist/nodes/Nbp/Nbp.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
